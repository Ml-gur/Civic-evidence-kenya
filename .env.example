# GEMINI_API_KEY: Required for Gemini AI API calls (optional feature).
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# Supabase Configuration
# Create a project at https://supabase.com and find these in Project Settings > API
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"


# Cloudinary Configuration
# Create a free account at https://cloudinary.com
# Upload preset must be set to "unsigned" in your Cloudinary settings
VITE_CLOUDINARY_CLOUD_NAME="your-cloud-name"
VITE_CLOUDINARY_UPLOAD_PRESET="your-upload-preset"
